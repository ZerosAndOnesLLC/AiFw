<?xml version="1.0"?>
<!-- A representative OPNsense 25.x config — covers every code path the
     importer reads. Real configs are 50–500 KB; this is the minimum that
     exercises rules, NAT (port-forward + outbound), aliases, gateways,
     static routes, IPv6, floating rules, self-closing tags, port aliases,
     and network keywords (which the importer skips with a note). -->
<opnsense>
  <version>25.7</version>
  <system>
    <hostname>fw1</hostname>
    <domain>example.com</domain>
    <dnsserver>1.1.1.1</dnsserver>
    <dnsserver>9.9.9.9</dnsserver>
    <timezone>UTC</timezone>
  </system>
  <aliases>
    <alias>
      <name>my_servers</name>
      <type>host</type>
      <content>10.0.0.5
10.0.0.6</content>
      <descr>web tier</descr>
    </alias>
    <alias>
      <name>blocked_nets</name>
      <type>network</type>
      <content>198.51.100.0/24</content>
    </alias>
  </aliases>
  <gateways>
    <gateway_item>
      <name>WAN_GW</name>
      <interface>wan</interface>
      <gateway>1.2.3.1</gateway>
      <ipprotocol>inet</ipprotocol>
    </gateway_item>
  </gateways>
  <filter>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet6</ipprotocol>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <address>2001:db8::1</address>
        <port>22</port>
      </destination>
      <descr>SSH to firewall (IPv6)</descr>
      <log/>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <protocol>tcp</protocol>
      <source><address>my_servers</address></source>
      <destination><any/><port>443</port></destination>
      <descr>web tier outbound HTTPS</descr>
    </rule>
    <rule>
      <type>block</type>
      <interface>wan,lan</interface>
      <floating>yes</floating>
      <protocol>any</protocol>
      <source><address>blocked_nets</address></source>
      <destination><any/></destination>
      <descr>block floating bad nets</descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <network>lanip</network>
        <port>80</port>
      </destination>
      <descr>captive portal — uses lanip keyword</descr>
    </rule>
  </filter>
  <nat>
    <outbound>
      <mode>hybrid</mode>
      <rule>
        <interface>wan</interface>
        <protocol>any</protocol>
        <source><address>10.0.0.0/8</address></source>
        <destination><any/></destination>
        <descr>masq lan</descr>
      </rule>
    </outbound>
    <rule>
      <interface>wan</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination>
        <network>wanip</network>
        <port>443</port>
      </destination>
      <target>10.0.0.10</target>
      <local-port>443</local-port>
      <descr>HTTPS forward</descr>
    </rule>
  </nat>
  <staticroutes>
    <route>
      <network>192.0.2.0/24</network>
      <gateway>WAN_GW</gateway>
      <descr>Test net via WAN</descr>
    </route>
  </staticroutes>
</opnsense>
