#!/bin/sh
# AiFw Install-to-Disk — clones live system to a target disk
# Supports ZFS and UFS with UEFI + legacy BIOS boot

AIFW_CONF="/usr/local/etc/aifw/aifw.conf"
INSTALL_ROOT=""
TARGET_DISK=""
FS_TYPE=""
SWAP_DEV=""

die() {
    echo "ERROR: $1" >&2
    echo ""
    echo "Press Enter to return..."
    read _
    exit 1
}

confirm() {
    echo ""
    echo -n "$1 [y/N] "
    read answer
    case "$answer" in
        [yY]*) return 0 ;;
        *) return 1 ;;
    esac
}

list_disks() {
    echo ""
    echo "Available disks:"
    echo "-----------------------------------------------------------"
    for disk in $(sysctl -n kern.disks 2>/dev/null); do
        case "$disk" in
            cd*|fd*|md*) continue ;;
        esac
        human=$(diskinfo -v "$disk" 2>/dev/null | grep 'mediasize in' | grep -v bytes | head -1 | sed 's/.*(//' | sed 's/)//')
        desc=$(camcontrol identify "$disk" 2>/dev/null | grep 'device model' | sed 's/.*: *//' || echo "unknown")
        printf "  %-10s %-20s %s\n" "$disk" "$human" "$desc"
    done
    echo "-----------------------------------------------------------"
}

select_disk() {
    list_disks
    echo ""
    echo -n "Enter target disk (e.g. da0, ada0, nvd0): "
    read TARGET_DISK

    if [ -z "$TARGET_DISK" ]; then
        die "No disk selected"
    fi

    if [ ! -e "/dev/$TARGET_DISK" ]; then
        die "Disk /dev/$TARGET_DISK does not exist"
    fi

    echo ""
    echo "WARNING: All data on /dev/$TARGET_DISK will be destroyed!"
    if ! confirm "Continue?"; then
        echo "Aborted."
        exit 0
    fi
}

select_filesystem() {
    echo ""
    echo "Select filesystem:"
    echo "  1) ZFS  (recommended — compression, snapshots, boot environments)"
    echo "  2) UFS  (traditional — lower memory usage)"
    echo ""
    echo -n "Choice [1]: "
    read fs_choice

    case "$fs_choice" in
        2)  FS_TYPE="ufs" ;;
        *)  FS_TYPE="zfs" ;;
    esac
}

partition_disk_zfs() {
    echo ""
    echo "Partitioning /dev/$TARGET_DISK for ZFS..."

    # Destroy existing partitions
    gpart destroy -F "$TARGET_DISK" 2>/dev/null || true
    dd if=/dev/zero of="/dev/$TARGET_DISK" bs=512 count=2048 >/dev/null 2>&1

    # Create GPT
    gpart create -s gpt "$TARGET_DISK" || die "Failed to create GPT"

    # EFI System Partition (260 MB)
    gpart add -t efi -s 260M -l efi "$TARGET_DISK"

    # FreeBSD boot partition (512K — for legacy BIOS)
    gpart add -t freebsd-boot -s 512K -l boot "$TARGET_DISK"

    # Swap (2 GB)
    gpart add -t freebsd-swap -s 2G -l swap0 "$TARGET_DISK"

    # ZFS partition (rest of disk)
    gpart add -t freebsd-zfs -l zfs0 "$TARGET_DISK"

    # Write legacy bootcode
    gpart bootcode -b /boot/pmbr -p /boot/gptzfsboot -i 2 "$TARGET_DISK"

    # Format EFI partition
    newfs_msdos -F 32 -c 1 "/dev/${TARGET_DISK}p1"
    mkdir -p /tmp/efi_mount
    mount -t msdos "/dev/${TARGET_DISK}p1" /tmp/efi_mount
    mkdir -p /tmp/efi_mount/EFI/BOOT
    cp /boot/loader.efi /tmp/efi_mount/EFI/BOOT/BOOTX64.efi
    umount /tmp/efi_mount

    # Create ZFS pool
    zpool create -f -o altroot=/mnt -O compress=lz4 -O atime=off \
        -O mountpoint=/ zroot "/dev/${TARGET_DISK}p4" || die "Failed to create ZFS pool"

    # Create datasets
    zfs create -o mountpoint=/tmp -o setuid=off zroot/tmp
    zfs create -o mountpoint=/usr zroot/usr
    zfs create zroot/usr/local
    zfs create zroot/usr/src
    zfs create -o mountpoint=/var zroot/var
    zfs create zroot/var/log
    zfs create zroot/var/db
    zfs create -o mountpoint=/home zroot/home

    # Set bootfs
    zpool set bootfs=zroot zroot

    INSTALL_ROOT="/mnt"
    SWAP_DEV="/dev/${TARGET_DISK}p3"
}

partition_disk_ufs() {
    echo ""
    echo "Partitioning /dev/$TARGET_DISK for UFS..."

    # Destroy existing partitions
    gpart destroy -F "$TARGET_DISK" 2>/dev/null || true
    dd if=/dev/zero of="/dev/$TARGET_DISK" bs=512 count=2048 >/dev/null 2>&1

    # Create GPT
    gpart create -s gpt "$TARGET_DISK" || die "Failed to create GPT"

    # EFI System Partition (260 MB)
    gpart add -t efi -s 260M -l efi "$TARGET_DISK"

    # FreeBSD boot partition (512K)
    gpart add -t freebsd-boot -s 512K -l boot "$TARGET_DISK"

    # Swap (2 GB)
    gpart add -t freebsd-swap -s 2G -l swap0 "$TARGET_DISK"

    # Root UFS partition (rest of disk)
    gpart add -t freebsd-ufs -l rootfs "$TARGET_DISK"

    # Write bootcode
    gpart bootcode -b /boot/pmbr -p /boot/gptboot -i 2 "$TARGET_DISK"

    # Format EFI partition
    newfs_msdos -F 32 -c 1 "/dev/${TARGET_DISK}p1"
    mkdir -p /tmp/efi_mount
    mount -t msdos "/dev/${TARGET_DISK}p1" /tmp/efi_mount
    mkdir -p /tmp/efi_mount/EFI/BOOT
    cp /boot/loader.efi /tmp/efi_mount/EFI/BOOT/BOOTX64.efi
    umount /tmp/efi_mount

    # Format root
    newfs -U -j "/dev/${TARGET_DISK}p4" || die "Failed to format UFS"
    mount "/dev/${TARGET_DISK}p4" /mnt || die "Failed to mount target"

    INSTALL_ROOT="/mnt"
    SWAP_DEV="/dev/${TARGET_DISK}p3"
}

clone_system() {
    echo ""
    echo "Cloning live system to $INSTALL_ROOT..."
    CLONE_ERRORS=0
    CLONE_LOG="/tmp/aifw-install.log"
    : > "$CLONE_LOG"

    # Use tar pipe to clone — more reliable than cpdup on cd9660
    for dir in bin boot etc lib libexec root sbin usr; do
        if [ -d "/$dir" ]; then
            echo "  Copying /$dir..."
            if ! tar -cf - -C / "$dir" 2>>"$CLONE_LOG" | tar -xpf - -C "$INSTALL_ROOT" 2>>"$CLONE_LOG"; then
                echo "  ERROR: failed to copy /$dir"
                CLONE_ERRORS=$((CLONE_ERRORS + 1))
            fi
        fi
    done

    # /var is tmpfs on the live CD, so create a proper var structure
    echo "  Creating /var structure..."
    mkdir -p "$INSTALL_ROOT/var"
    for vdir in cache db db/pkg db/aifw db/rdhcpd db/rdhcpd/leases \
                empty games heimdal log log/aifw \
                log/trafficcop log/rdhcpd log/rdns log/rtime \
                mail msgs preserve run run/rdns run/rtime \
                rwho spool spool/lock spool/output \
                tmp unbound yp; do
        mkdir -p "$INSTALL_ROOT/var/$vdir"
    done
    chmod 1777 "$INSTALL_ROOT/var/tmp"
    chmod 0555 "$INSTALL_ROOT/var/empty"

    # Create service config directories
    mkdir -p "$INSTALL_ROOT/usr/local/etc/rdhcpd"
    mkdir -p "$INSTALL_ROOT/usr/local/etc/rdns/zones"
    mkdir -p "$INSTALL_ROOT/usr/local/etc/rdns/rpz"
    mkdir -p "$INSTALL_ROOT/usr/local/etc/rtime"
    mkdir -p "$INSTALL_ROOT/usr/local/etc/trafficcop"

    # Set ownership for service directories (aifw user UID 470)
    chown -R 470:470 "$INSTALL_ROOT/var/db/aifw" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/log/aifw" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/log/trafficcop" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/db/rdhcpd" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/log/rdhcpd" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/usr/local/etc/rdhcpd" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/log/rdns" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/usr/local/etc/rtime" 2>/dev/null || true
    chown -R 470:470 "$INSTALL_ROOT/var/log/rtime" 2>/dev/null || true

    # Verify critical system files exist
    for f in usr/libexec/getty libexec/ld-elf.so.1 bin/sh sbin/init; do
        if [ ! -f "$INSTALL_ROOT/$f" ]; then
            echo "  WARNING: Missing critical file /$f — retrying copy..."
            tar -cf - -C / "$(dirname $f)" 2>/dev/null | tar -xpf - -C "$INSTALL_ROOT" 2>/dev/null
        fi
    done

    # Create other required directories
    mkdir -p "$INSTALL_ROOT/dev"
    mkdir -p "$INSTALL_ROOT/mnt"
    mkdir -p "$INSTALL_ROOT/proc"
    mkdir -p "$INSTALL_ROOT/tmp"
    chmod 1777 "$INSTALL_ROOT/tmp"
    mkdir -p "$INSTALL_ROOT/home"
    mkdir -p "$INSTALL_ROOT/usr/local/share/aifw"

    # Copy AiFw config if setup was already run
    if [ -f "$AIFW_CONF" ]; then
        echo "  Copying AiFw configuration..."
        mkdir -p "$INSTALL_ROOT/usr/local/etc/aifw"
        cp -a /usr/local/etc/aifw/* "$INSTALL_ROOT/usr/local/etc/aifw/" 2>/dev/null || true
        mkdir -p "$INSTALL_ROOT/var/db/aifw"
        cp -a /var/db/aifw/* "$INSTALL_ROOT/var/db/aifw/" 2>/dev/null || true
    fi

    # Copy TrafficCop config
    if [ -d /usr/local/etc/trafficcop ]; then
        echo "  Copying TrafficCop configuration..."
        mkdir -p "$INSTALL_ROOT/usr/local/etc/trafficcop"
        cp -a /usr/local/etc/trafficcop/* "$INSTALL_ROOT/usr/local/etc/trafficcop/" 2>/dev/null || true
        chown -R 470:470 "$INSTALL_ROOT/usr/local/etc/trafficcop" 2>/dev/null || true
    fi

    # Verify critical files exist
    echo ""
    echo "  Verifying installation..."
    VERIFY_FAILED=0
    for check in boot/loader boot/kernel/kernel sbin/init etc/rc bin/sh usr/local/sbin/aifw-setup; do
        if [ ! -f "$INSTALL_ROOT/$check" ]; then
            echo "  MISSING: /$check"
            VERIFY_FAILED=$((VERIFY_FAILED + 1))
        fi
    done

    if [ "$VERIFY_FAILED" -gt 0 ]; then
        echo ""
        echo "  $VERIFY_FAILED critical file(s) missing!"
        echo "  Clone log: $CLONE_LOG"
        cat "$CLONE_LOG"
        die "Installation failed — critical files missing from target disk"
    fi

    if [ "$CLONE_ERRORS" -gt 0 ]; then
        echo ""
        echo "  WARNING: $CLONE_ERRORS directory(s) had copy errors."
        echo "  Clone log: $CLONE_LOG"
        cat "$CLONE_LOG"
        echo ""
        echo -n "  Continue anyway? [y/N] "
        read cont
        case "$cont" in
            [yY]*) ;;
            *) die "Installation aborted by user" ;;
        esac
    else
        echo "  All files verified OK."
    fi
}

write_fstab_zfs() {
    cat > "$INSTALL_ROOT/etc/fstab" <<FSTAB
# Device        Mountpoint  FStype  Options Dump    Pass#
$SWAP_DEV       none        swap    sw      0       0
fdesc           /dev/fd     fdescfs rw      0       0
proc            /proc       procfs  rw      0       0
FSTAB
}

write_fstab_ufs() {
    cat > "$INSTALL_ROOT/etc/fstab" <<FSTAB
# Device                Mountpoint  FStype  Options     Dump    Pass#
/dev/${TARGET_DISK}p4   /           ufs     rw          1       1
$SWAP_DEV               none        swap    sw          0       0
fdesc                   /dev/fd     fdescfs rw          0       0
proc                    /proc       procfs  rw          0       0
FSTAB
}

write_rc_conf() {
    # Preserve existing rc.conf and ensure key settings
    if [ ! -f "$INSTALL_ROOT/etc/rc.conf" ]; then
        touch "$INSTALL_ROOT/etc/rc.conf"
    fi

    # Use sysrc pointed at the installed root
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" hostname="aifw"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" pf_enable="YES"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" pf_rules="/usr/local/etc/aifw/pf.conf.aifw"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" pflog_enable="YES"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" gateway_enable="YES"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" sshd_enable="YES"

    # Enable/disable AiFw services based on whether setup was run
    if [ -f "$AIFW_CONF" ]; then
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_daemon_enable="YES"
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_api_enable="YES"
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_firstboot_enable="NO"
    else
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_firstboot_enable="YES"
    fi

    # Copy network interface settings from live system
    for var in $(sysrc -aN 2>/dev/null | grep -E '^ifconfig_|^defaultrouter'); do
        val=$(sysrc -n "$var" 2>/dev/null)
        if [ -n "$val" ]; then
            sysrc -f "$INSTALL_ROOT/etc/rc.conf" "${var}=${val}"
        fi
    done

    # Copy service enable flags from live system
    for svc in rdhcpd rdns rtime trafficcop; do
        val=$(sysrc -n "${svc}_enable" 2>/dev/null)
        if [ -n "$val" ]; then
            sysrc -f "$INSTALL_ROOT/etc/rc.conf" "${svc}_enable=${val}"
        fi
    done

    # TrafficCop disabled by default if not already set
    if ! sysrc -f "$INSTALL_ROOT/etc/rc.conf" -c trafficcop_enable 2>/dev/null; then
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" trafficcop_enable="NO"
    fi

    # ZFS-specific
    if [ "$FS_TYPE" = "zfs" ]; then
        sysrc -f "$INSTALL_ROOT/etc/rc.conf" zfs_enable="YES"
    fi
}

write_loader_conf() {
    cat > "$INSTALL_ROOT/boot/loader.conf" <<LOADER
autoboot_delay="3"
kern.geom.label.disk_ident.enable="0"
kern.geom.label.gptid.enable="0"
LOADER

    if [ "$FS_TYPE" = "zfs" ]; then
        echo 'zfs_load="YES"' >> "$INSTALL_ROOT/boot/loader.conf"
        echo 'vfs.root.mountfrom="zfs:zroot"' >> "$INSTALL_ROOT/boot/loader.conf"
    fi

    # Copy AiFw tuning if present
    if [ -f /boot/loader.conf.aifw ]; then
        echo "" >> "$INSTALL_ROOT/boot/loader.conf"
        echo "# AiFw kernel tuning" >> "$INSTALL_ROOT/boot/loader.conf"
        cat /boot/loader.conf.aifw >> "$INSTALL_ROOT/boot/loader.conf"
    fi
}

# Configure ttys for installed system
fix_ttys() {
    # ttyv0: auto-login to console menu on physical terminal
    sed -i '' 's|^ttyv0.*|ttyv0 "/usr/libexec/getty autologin" xterm on secure|' "$INSTALL_ROOT/etc/ttys"

    # Disable unused virtual terminals (ttyv1-ttyv8) — appliance only uses ttyv0
    for vt in ttyv1 ttyv2 ttyv3 ttyv4 ttyv5 ttyv6 ttyv7 ttyv8; do
        sed -i '' "s|^${vt}.*|${vt} \"/usr/libexec/getty Pc\" xterm off secure|" "$INSTALL_ROOT/etc/ttys"
    done

    # Ensure gettytab has autologin entry
    if ! grep -q 'autologin' "$INSTALL_ROOT/etc/gettytab" 2>/dev/null; then
        cat >> "$INSTALL_ROOT/etc/gettytab" <<'GETTY'

# Auto-login for AiFw console
autologin|al|Auto login:\
    :ht:np:sp#115200:al=root:lo=/usr/local/sbin/aifw-console:
GETTY
    fi

    # Ensure aifw-console is in /etc/shells
    if ! grep -q 'aifw-console' "$INSTALL_ROOT/etc/shells" 2>/dev/null; then
        echo "/usr/local/sbin/aifw-console" >> "$INSTALL_ROOT/etc/shells"
    fi
}

cleanup() {
    echo "Cleaning up..."
    sync
    if [ "$FS_TYPE" = "zfs" ]; then
        zfs unmount -a 2>/dev/null || true
        zpool export zroot 2>/dev/null || true
    else
        umount "$INSTALL_ROOT" 2>/dev/null || true
    fi
}

# --- Main ---

echo ""
echo "============================================"
echo "  AiFw — Install to Disk"
echo "============================================"
echo ""

# Must be root
if [ "$(id -u)" -ne 0 ]; then
    die "Must be run as root"
fi

select_disk
select_filesystem

trap cleanup EXIT

if [ "$FS_TYPE" = "zfs" ]; then
    partition_disk_zfs
    clone_system
    write_fstab_zfs
else
    partition_disk_ufs
    clone_system
    write_fstab_ufs
fi

write_rc_conf
write_loader_conf
fix_ttys

sync

# --- Run setup wizard on the installed system ---
echo ""
echo "============================================"
echo "  AiFw — Initial Configuration"
echo "============================================"
echo ""

# Mount devfs so the chrooted setup can access devices
mkdir -p "$INSTALL_ROOT/dev"
mount -t devfs devfs "$INSTALL_ROOT/dev"

# Copy resolv.conf so setup has DNS
cp /etc/resolv.conf "$INSTALL_ROOT/etc/resolv.conf" 2>/dev/null || true

# Run setup wizard chrooted into the installed system
chroot "$INSTALL_ROOT" /usr/local/sbin/aifw-setup

umount "$INSTALL_ROOT/dev" 2>/dev/null || true

# If setup succeeded, enable services in the installed rc.conf
if [ -f "$INSTALL_ROOT/usr/local/etc/aifw/aifw.conf" ]; then
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_daemon_enable="YES"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_api_enable="YES"
    sysrc -f "$INSTALL_ROOT/etc/rc.conf" aifw_firstboot_enable="NO"
    echo ""
    echo "  Setup complete — services will start on boot."
else
    echo ""
    echo "  Setup was skipped — the wizard will run on first login."
fi

sync

# Get the IP for display
DISPLAY_IP=$(ifconfig em0 2>/dev/null | grep 'inet ' | awk '{print $2}' | head -1)
[ -z "$DISPLAY_IP" ] && DISPLAY_IP="<your-ip>"

echo ""
echo "============================================"
echo "  Installation complete!"
echo "============================================"
echo ""
echo "  Status:     SUCCESS"
echo "  Disk:       /dev/$TARGET_DISK"
echo "  Filesystem: $FS_TYPE"
echo ""
echo "  After reboot, you can manage AiFw using:"
echo ""
echo "    Console Menu  Login at the console to access the management menu"
echo "    Web UI        https://${DISPLAY_IP}:8080/"
echo "    CLI           aifw rules list, aifw status, aifw --help"
echo "    TUI           aifw-tui"
echo "    API           https://${DISPLAY_IP}:8080/api/v1/"
echo ""
echo "  +-------------------------------------------------+"
echo "  |  Please remove the CD/DVD or USB drive before   |"
echo "  |  rebooting so the system boots from disk.       |"
echo "  +-------------------------------------------------+"
echo ""
echo -n "  Press Enter to reboot..."
read _
reboot
