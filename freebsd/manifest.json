{
  "_comment": "Single source of truth for all AiFw components. Used by: updater, CI build, ISO builder, deploy script.",

  "binaries": {
    "_comment": "Binaries built from this repo (cargo build --release)",
    "local": ["aifw", "aifw-daemon", "aifw-api", "aifw-ids", "aifw-tui", "aifw-setup"]
  },

  "external_repos": [
    {
      "name": "TrafficCop",
      "repo": "ZerosAndOnesLLC/TrafficCop",
      "binaries": ["trafficcop"]
    },
    {
      "name": "rDHCP",
      "repo": "ZerosAndOnesLLC/rDHCP",
      "binaries": ["rdhcpd"]
    },
    {
      "name": "rDNS",
      "repo": "ZerosAndOnesLLC/rDNS",
      "binaries": ["rdns", "rdns-control"]
    },
    {
      "name": "rTIME",
      "repo": "ZerosAndOnesLLC/rTIME",
      "binaries": ["rtime"]
    }
  ],

  "rc_scripts": [
    "aifw_api",
    "aifw_daemon",
    "aifw_firstboot",
    "aifw_ids",
    "aifw_watchdog",
    "rdhcpd",
    "rdns",
    "rtime",
    "trafficcop"
  ],

  "sbin_scripts": [
    "aifw-console",
    "aifw-install"
  ],

  "libexec_scripts": [
    "aifw-login-migrate.sh",
    "aifw-motd-cleanup.sh",
    "aifw-restart.sh",
    "aifw-watchdog.sh"
  ],

  "directories": [
    "/usr/local/etc/aifw",
    "/usr/local/etc/aifw/anchors",
    "/usr/local/share/aifw",
    "/var/db/aifw",
    "/var/log/aifw",
    "/var/log/trafficcop",
    "/var/db/rdhcpd/leases",
    "/var/log/rdhcpd",
    "/usr/local/etc/rdhcpd",
    "/usr/local/etc/rdns/zones",
    "/usr/local/etc/rdns/rpz",
    "/var/run/rdns",
    "/var/log/rdns",
    "/usr/local/etc/rtime",
    "/var/run/rtime",
    "/var/log/rtime",
    "/usr/local/lib/aifw/plugins"
  ]
}
